# =================================================================
# GITIGNORE PADRÃO PARA ENGENHARIA E DESENVOLVIMENTO
# =================================================================

# === Arquivos de Sistema (Windows, macOS, Linux) ===
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk
ehthumbs.db
Icon?

# === Documentos e Office (Temporários e Arquivos Finais) ===
# Ignora arquivos temporários (que começam com ~$) e documentos
~$*.doc*
~$*.xls*
~$*.ppt*
*.tmp
*.docx
*.doc
*.xlsx
*.xls
*.pptx
*.ppt


# === Arquivos Comprimidos ===
*.zip
*.rar
*.7z
*.tar
*.gz
*.iso

